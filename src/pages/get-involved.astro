---
import SiteLayout from '../layouts/SiteLayout.astro';
import {
	BookOpen,
	Calendar,
	Heart,
	Sprout,
	Users,
	Wrench,
} from '@lucide/astro';

const opportunities = [
	{
		title: 'Plot Holder',
		icon: 'sprout',
		commitment: 'Ongoing',
		description: 'Grow your own produce on one of our community allotment plots.',
		requirements: [
			'Basic commitment to maintain a plot',
			'Attendance at quarterly meetings',
			'Annual membership fee',
		],
		cardClass: 'from-green-100 to-green-200 ring-green-300',
	},
	{
		title: 'Workshop Leader',
		icon: 'book-open',
		commitment: '2-4 hours per month',
		description:
			'Share your expertise by leading workshops on growing, cooking, or preserving.',
		requirements: [
			'Knowledge in a specific area',
			'Good communication skills',
			'Preparation time for sessions',
		],
		cardClass: 'from-sky-100 to-blue-200 ring-blue-300',
	},
	{
		title: 'Event Organiser',
		icon: 'calendar',
		commitment: '4-6 hours per month',
		description:
			'Help plan and coordinate community events, socials, and working parties.',
		requirements: [
			'Organisational skills',
			'Flexibility with scheduling',
			'Team player attitude',
		],
		cardClass: 'from-violet-100 to-fuchsia-100 ring-violet-300',
	},
	{
		title: 'Maintenance Volunteer',
		icon: 'wrench',
		commitment: 'Flexible',
		description: 'Help maintain shared spaces, tools, and infrastructure.',
		requirements: [
			'Basic DIY skills are helpful',
			'Physical ability for outdoor work',
			'Reliable attendance',
		],
		cardClass: 'from-amber-100 to-orange-200 ring-orange-300',
	},
	{
		title: 'Mentor',
		icon: 'users',
		commitment: '1-2 hours per week',
		description: 'Guide new members and beginners through their growing journey.',
		requirements: [
			'Growing experience',
			'Patient and supportive approach',
			'Regular availability',
		],
		cardClass: 'from-yellow-100 to-lime-100 ring-yellow-300',
	},
	{
		title: 'Committee Member',
		icon: 'heart',
		commitment: '3-5 hours per month',
		description: 'Join the steering committee and help guide the organisation.',
		requirements: [
			'Commitment to meetings',
			'Decision-making responsibility',
			'Strategic thinking',
		],
		cardClass: 'from-rose-100 to-pink-100 ring-pink-300',
	},
] as const;

const steps = [
	{
		number: '1',
		title: 'Choose a Role',
		description: 'Browse the opportunities and find the kind of involvement that suits you.',
	},
	{
		number: '2',
		title: 'Get in Touch',
		description: 'Contact the group or come along to an event to express your interest.',
	},
	{
		number: '3',
		title: 'Meet the Team',
		description: 'Chat with current members to learn more about the role and how things work.',
	},
	{
		number: '4',
		title: 'Start Contributing',
		description: 'Begin getting involved in a way that feels manageable and rewarding.',
	},
] as const;

const stories = [
	{
		quote:
			'I started as a complete beginner and now I mentor new members. The community has given me so much confidence and knowledge, and it feels great to pass that on.',
		name: 'James',
		role: 'Mentor Volunteer',
		memberSince: 'Member since 2023',
		cardClass: 'bg-green-50 ring-green-200',
	},
	{
		quote:
			'Leading workshops has been amazing. I love sharing preserving skills and seeing people light up when they make their first jam successfully.',
		name: 'Margaret',
		role: 'Workshop Leader',
		memberSince: 'Member since 2022',
		cardClass: 'bg-sky-50 ring-sky-200',
	},
] as const;

const iconMap = {
	sprout: Sprout,
	'book-open': BookOpen,
	calendar: Calendar,
	wrench: Wrench,
	users: Users,
	heart: Heart,
};
---

<SiteLayout title="Get Involved">
	<div class="space-y-8">
		<section class="rounded-4xl bg-linear-to-br from-stone-50 via-lime-50/70 to-emerald-100/60 px-5 py-8 sm:px-8 sm:py-12">
			<div class="max-w-3xl">
				<h1 class="text-4xl font-bold tracking-tight text-stone-900 sm:text-5xl">
					Get Involved
				</h1>
				<p class="mt-4 max-w-2xl text-lg leading-8 text-stone-700">
					Discover the many ways you can contribute to our growing community, whether
					you want to volunteer regularly or just lend a hand when you can.
				</p>
			</div>
		</section>

		<section class="rounded-4xl bg-linear-to-r from-green-800 to-lime-700 px-6 py-8 text-white shadow-lg sm:px-8 sm:py-10">
			<h2 class="text-3xl font-bold tracking-tight">Join Our Community</h2>
			<p class="mt-4 max-w-3xl text-lg leading-8 text-green-50">
				Whether you have five minutes or five hours to spare, there is a meaningful way
				to contribute. Every member brings different skills, knowledge, and energy to the
				group. No experience is necessary, only curiosity and a willingness to learn.
			</p>

			<div class="mt-8 grid gap-4 sm:grid-cols-3">
				<div class="rounded-3xl bg-white/10 px-5 py-5 text-center backdrop-blur-sm">
					<p class="text-3xl font-bold">50+</p>
					<p class="mt-1 text-sm text-green-50">Active volunteers</p>
				</div>
				<div class="rounded-3xl bg-white/10 px-5 py-5 text-center backdrop-blur-sm">
					<p class="text-3xl font-bold">12</p>
					<p class="mt-1 text-sm text-green-50">Different roles</p>
				</div>
				<div class="rounded-3xl bg-white/10 px-5 py-5 text-center backdrop-blur-sm">
					<p class="text-3xl font-bold">100%</p>
					<p class="mt-1 text-sm text-green-50">Community led</p>
				</div>
			</div>
		</section>

		<section>
			<h2 class="text-2xl font-bold tracking-tight text-stone-900">Volunteer Opportunities</h2>
			<div class="mt-6 grid gap-5 md:grid-cols-2">
				{
					opportunities.map((opportunity) => {
						const Icon = iconMap[opportunity.icon];

						return (
							<article
								class:list={[
									'rounded-4xl bg-linear-to-br p-6 ring-1 shadow-sm transition duration-300 hover:shadow-lg',
									opportunity.cardClass,
								]}
							>
								<div class="flex items-start gap-4">
									<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white text-green-800">
										<Icon class="h-6 w-6" />
									</div>
									<div class="min-w-0 flex-1">
										<h3 class="text-2xl font-bold tracking-tight text-stone-900">
											{opportunity.title}
										</h3>
										<p class="mt-1 text-sm font-semibold text-stone-600">
											Time commitment: {opportunity.commitment}
										</p>
									</div>
								</div>

								<p class="mt-5 text-base leading-7 text-stone-700">
									{opportunity.description}
								</p>

								<div class="mt-5">
									<p class="text-sm font-semibold text-stone-900">What you'll need</p>
									<ul class="mt-3 space-y-2 text-sm leading-6 text-stone-700">
										{
											opportunity.requirements.map((requirement) => (
												<li class="flex items-start gap-2">
													<span class="mt-0.5 text-green-800">-</span>
													<span>{requirement}</span>
												</li>
											))
										}
									</ul>
								</div>

								<a
									href="/contact"
									class="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-green-800 px-4 py-3 text-center font-semibold text-white transition hover:bg-green-900"
								>
									Express Interest
								</a>
							</article>
						);
					})
				}
			</div>
		</section>

		<section class="rounded-4xl border border-stone-200 bg-white p-6 shadow-sm sm:p-8">
			<h2 class="text-2xl font-bold tracking-tight text-stone-900">How to Get Started</h2>
			<div class="mt-6 grid gap-6 md:grid-cols-4">
				{
					steps.map((step) => (
						<div class="text-center">
							<div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100 text-2xl font-bold text-green-800">
								{step.number}
							</div>
							<h3 class="mt-4 text-lg font-bold text-stone-900">{step.title}</h3>
							<p class="mt-2 text-sm leading-6 text-stone-600">{step.description}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="rounded-4xl border border-stone-200 bg-white p-6 shadow-sm sm:p-8">
			<h2 class="text-2xl font-bold tracking-tight text-stone-900">Volunteer Stories</h2>
			<div class="mt-6 grid gap-5 md:grid-cols-2">
				{
					stories.map((story) => (
						<article class:list={['rounded-3xl p-6 ring-1', story.cardClass]}>
							<p class="text-base leading-8 text-stone-700 italic">"{story.quote}"</p>
							<p class="mt-5 font-semibold text-stone-900">
								{story.name}, {story.role}
							</p>
							<p class="mt-1 text-sm text-stone-600">{story.memberSince}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="rounded-4xl bg-linear-to-r from-amber-50 to-green-50 px-6 py-8 text-center ring-1 ring-green-700 sm:px-8 sm:py-10">
			<h2 class="text-2xl font-bold tracking-tight text-stone-900">
				Ready to Make a Difference?
			</h2>
			<p class="mx-auto mt-3 max-w-2xl leading-8 text-stone-700">
				Get in touch to chat about how you could contribute to the group. We would love to
				hear from you and help you find the right way to get involved.
			</p>
			<a
				href="/contact"
				class="mt-6 inline-flex items-center justify-center rounded-2xl bg-green-800 px-8 py-3 font-semibold text-white transition hover:bg-green-900"
			>
				Contact Us
			</a>
		</section>
	</div>
</SiteLayout>
