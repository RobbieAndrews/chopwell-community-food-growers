---
import SiteLayout from '../layouts/SiteLayout.astro';
import FullBleedSection from '../components/FullBleedSection.astro';
import PageIntro from '../components/PageIntro.astro';
import { PortableText } from 'astro-portabletext';
import type { TypedObject } from 'astro-portabletext/types';
import { sanityClient } from 'sanity:client';
import { projectIconMap, type ProjectIcon } from '../lib/projectIcons';
import { HeartHandshake, Leaf, Users } from '@lucide/astro';

interface VolunteerOpportunity {
	title: string;
	icon: ProjectIcon;
	timeCommitment: string;
	description: TypedObject[];
}

const VOLUNTEER_OPPORTUNITIES_QUERY = `*[
	_type == "volunteerOpportunity"
]|order(title asc){
	title,
	icon,
	timeCommitment,
	description
}`;

const opportunities = await sanityClient.fetch<VolunteerOpportunity[]>(
	VOLUNTEER_OPPORTUNITIES_QUERY
);

const steps = [
	{
		number: '1',
		title: 'Choose a Role',
		description: 'Browse the opportunities and find the kind of involvement that suits you.',
	},
	{
		number: '2',
		title: 'Get in Touch',
		description: 'Contact the group or come along to an event to express your interest.',
	},
	{
		number: '3',
		title: 'Meet the Team',
		description: 'Chat with current members to learn more about the role and how things work.',
	},
	{
		number: '4',
		title: 'Start Contributing',
		description: 'Begin getting involved in a way that feels manageable and rewarding.',
	},
] as const;

const stories = [
	{
		quote:
			'I started as a complete beginner and now I mentor new members. The community has given me so much confidence and knowledge, and it feels great to pass that on.',
		name: 'James',
		role: 'Mentor Volunteer',
		memberSince: 'Member since 2023',
		cardClass: 'bg-green-50 ring-green-200',
	},
	{
		quote:
			'Leading workshops has been amazing. I love sharing preserving skills and seeing people light up when they make their first jam successfully.',
		name: 'Margaret',
		role: 'Workshop Leader',
		memberSince: 'Member since 2022',
		cardClass: 'bg-sky-50 ring-sky-200',
	},
] as const;
---

<SiteLayout title="Get Involved">
	<div class="space-y-8">
		<PageIntro
			title="Get Involved"
			description="Discover the many ways you can contribute to our growing community, whether you want to volunteer regularly or just lend a hand when you can."
			pills={[
				{ label: '50+ active volunteers', icon: Users, iconClass: 'text-green-700' },
				{ label: '12 different roles', icon: Leaf, iconClass: 'text-sky-700' },
				{ label: 'Friendly and flexible', icon: HeartHandshake, iconClass: 'text-amber-600' },
			]}
		/>

		<FullBleedSection class="py-12" bleedClass="bleed-white-70">
				<h2 class="text-3xl font-bold tracking-tight text-gray-900">Volunteer Opportunities</h2>
				{
					opportunities.length ? (
						<div class="mt-6 grid gap-5 md:grid-cols-2">
							{
								opportunities.map((opportunity) => {
									const Icon = projectIconMap[opportunity.icon] ?? projectIconMap.users;

									return (
										<article class="rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 transition duration-300 hover:-translate-y-1 hover:shadow-2xl">
											<div class="flex items-start gap-4">
												<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-green-100 text-green-800">
													<Icon class="h-6 w-6" />
												</div>
												<div class="min-w-0 flex-1">
													<h3 class="text-2xl font-bold tracking-tight text-gray-900">
														{opportunity.title}
													</h3>
													<p class="mt-1 text-sm font-semibold text-gray-500">
														Time commitment: {opportunity.timeCommitment}
													</p>
												</div>
											</div>

											<div class="portable-content mt-5 max-w-none">
												<PortableText value={opportunity.description} />
											</div>

											<a
												href="/contact"
												class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-[#2d5016] px-4 py-3 text-center font-semibold text-white transition hover:bg-[#244111]"
											>
												Express Interest
											</a>
										</article>
									);
								})
							}
						</div>
					) : (
						<div class="mt-6 rounded-4xl border border-dashed border-gray-300 bg-white/80 p-8 text-center text-gray-600">
							Add some `Volunteer Opportunity` documents in Sanity Studio and they will appear here.
						</div>
					)
				}
		</FullBleedSection>

		<section class="rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 sm:p-8">
			<h2 class="text-2xl font-bold tracking-tight text-gray-900">How to Get Started</h2>
			<div class="mt-6 grid gap-6 md:grid-cols-4">
				{
					steps.map((step) => (
						<div class="text-center">
							<div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100 text-2xl font-bold text-green-800">
								{step.number}
							</div>
							<h3 class="mt-4 text-lg font-bold text-gray-900">{step.title}</h3>
							<p class="mt-2 text-sm leading-6 text-gray-600">{step.description}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class="rounded-4xl bg-[#2d5016] px-6 py-8 text-center text-white shadow-2xl sm:px-8 sm:py-10">
			<h2 class="text-2xl font-bold tracking-tight">Ready to Make a Difference?</h2>
			<p class="mx-auto mt-3 max-w-2xl leading-8 text-green-50">
				Get in touch to chat about how you could contribute to the group. We would love to
				hear from you and help you find the right way to get involved.
			</p>
			<a
				href="/contact"
				class="mt-6 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 font-semibold text-[#2d5016] transition hover:bg-green-50"
			>
				Contact Us
			</a>
		</section>
	</div>
</SiteLayout>
