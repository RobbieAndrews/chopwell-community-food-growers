---
import SiteLayout from '../layouts/SiteLayout.astro';
import { ArrowRight, House, Leaf, Utensils } from '@lucide/astro';
import { projects } from '../data/projects';

const iconMap = {
	leaf: Leaf,
	house: House,
	utensils: Utensils,
};
---

<SiteLayout title="Projects">
	<section class="rounded-4xl bg-linear-to-br from-stone-50 via-lime-50/70 to-emerald-100/60 px-5 py-8 sm:px-8 sm:py-12">
		<div class="max-w-3xl">
			<h1 class="text-4xl font-bold tracking-tight text-stone-900 sm:text-5xl">
				Community Projects
			</h1>
			<p class="mt-4 max-w-2xl text-lg leading-8 text-stone-700">
				Explore the growing spaces, shared skills, and practical projects helping Chopwell
				build a stronger local food community.
			</p>
		</div>
	</section>

	<section class="mt-8">
		<div class="grid gap-5 md:grid-cols-3">
			{
				projects.map((project) => {
					const Icon = iconMap[project.icon];

					return (
						<a
							href={`/projects/${project.slug}`}
							class="group overflow-hidden rounded-4xl border border-stone-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl"
						>
							<div class="relative aspect-4/3 overflow-hidden">
								<img
									src={project.imageUrl}
									alt={project.title}
									loading="lazy"
									class="h-full w-full object-cover"
								/>
							</div>

							<div class="p-5 sm:p-6">
								<div class="flex items-start gap-4">
									<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-green-100 text-green-900">
										<Icon class="h-6 w-6" />
									</div>
                                    <h2 class="text-2xl font-bold tracking-tight text-stone-900">
                                        {project.title}
                                    </h2>
								</div>
                                <div class="min-w-0 flex-1">
                                    <p class="mt-3 text-base leading-7 text-stone-700">
                                        {project.description}
                                    </p>
                                </div>

								<div class="mt-6 flex items-center gap-2 font-semibold text-green-900">
									<span>Explore project</span>
									<ArrowRight class="h-4 w-4 transition group-hover:translate-x-1" />
								</div>
							</div>
						</a>
					);
				})
			}
		</div>
	</section>
</SiteLayout>
