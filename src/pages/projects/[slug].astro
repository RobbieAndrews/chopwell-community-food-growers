---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { ArrowLeft } from '@lucide/astro';
import { PortableText } from 'astro-portabletext';
import { sanityClient } from 'sanity:client';
import ContentFeatureCard from '../../components/ContentFeatureCard.astro';
import {
	articlePortableTextComponents,
	type ArticlePortableTextBlock,
} from '../../lib/articlePortableText';
import { projectIconMap, type ProjectIcon } from '../../lib/projectIcons';
import {
	getSanityImageSrcSet,
	getSanityImageUrl,
	type SanityImageWithAlt,
} from '../../lib/sanity';

interface ProjectPage {
	_id: string;
	title: string;
	slug: { current: string };
	headline: string;
	icon: ProjectIcon;
	mainImage?: SanityImageWithAlt;
	body?: ArticlePortableTextBlock[];
}

export async function getStaticPaths(): Promise<{ params: { slug: string } }[]> {
	const PROJECT_SLUGS_QUERY = `*[
		_type == "project"
		&& defined(slug.current)
	]{
		"params": { "slug": slug.current }
	}`;

	return await sanityClient.fetch(PROJECT_SLUGS_QUERY);
}

const PROJECT_QUERY = `*[
	_type == "project"
	&& slug.current == $slug
][0]{
	_id,
	title,
	slug,
	headline,
	icon,
	mainImage,
	body
}`;

const project = await sanityClient.fetch<ProjectPage | null>(PROJECT_QUERY, {
	slug: Astro.params.slug,
});

if (!project) {
	return Astro.redirect('/projects');
}

const Icon = projectIconMap[project.icon] ?? projectIconMap.leaf;
const projectHeroWidths = [640, 960, 1280, 1600];
const projectHeroAspectRatio = 1280 / 822;
const projectImageUrl = project.mainImage
	? getSanityImageUrl(project.mainImage, {
			width: 1280,
			aspectRatio: projectHeroAspectRatio,
			fit: 'crop',
		})
	: null;
const projectImageSrcSet = project.mainImage
	? getSanityImageSrcSet(project.mainImage, projectHeroWidths, {
			aspectRatio: projectHeroAspectRatio,
			fit: 'crop',
		})
	: '';
const projectImageAlt = project.mainImage?.alt || project.title;
---

<SiteLayout title={project.title}>
	<div class="space-y-8">
		<a
			href="/projects"
			class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-md ring-1 ring-gray-100 transition hover:bg-green-50 hover:text-[#2d5016]"
		>
			<ArrowLeft class="h-4 w-4" />
			<span>Back to projects</span>
		</a>

		<ContentFeatureCard articleTitle="About this project">
			<Fragment slot="intro">
				<div class="flex items-center gap-4">
					<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-green-100 text-green-900">
						<Icon class="h-7 w-7" />
					</div>
					<h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
						{project.title}
					</h1>
				</div>

				<p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600">{project.headline}</p>
			</Fragment>

			<Fragment slot="media">
				{
					projectImageUrl ? (
						<img
							src={projectImageUrl}
							srcset={projectImageSrcSet || undefined}
							sizes="(min-width: 1024px) 45vw, 100vw"
							alt={projectImageAlt}
							loading="eager"
							fetchpriority="high"
							decoding="async"
							width="1280"
							height="822"
							class="aspect-[1280/822] h-full min-h-72 w-full object-cover"
						/>
					) : (
						<div class="flex h-full min-h-72 items-center justify-center bg-linear-to-br from-lime-100 via-stone-50 to-emerald-100 text-green-900">
							<Icon class="h-16 w-16" />
						</div>
					)
				}
			</Fragment>

			{
				Array.isArray(project.body) && project.body.length && (
					<div class="mt-5">
						<PortableText value={project.body} components={articlePortableTextComponents} />
					</div>
				)
			}
		</ContentFeatureCard>
	</div>
</SiteLayout>
