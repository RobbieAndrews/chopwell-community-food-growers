---
import { ExternalLink, Leaf, LibraryBig, Users } from '@lucide/astro';
import { sanityClient } from 'sanity:client';
import FullBleedSection from '../components/FullBleedSection.astro';
import PageIntro from '../components/PageIntro.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { projectIconMap, type ProjectIcon } from '../lib/projectIcons';

interface UsefulLinkItem {
	_key?: string;
	title: string;
	url: string;
	description: string;
}

interface UsefulLinkSection {
	_id: string;
	_key?: string;
	title: string;
	icon: ProjectIcon;
	color: UsefulLinkSectionColor;
	links: UsefulLinkItem[];
	order?: number;
}

type UsefulLinkSectionColor = 'green' | 'amber' | 'sky' | 'violet' | 'rose' | 'gray';

const USEFUL_LINK_SECTIONS_QUERY = `*[
	_type == "usefulLinkSection"
]|order(order asc, title asc){
	_id,
	title,
	icon,
	color,
	order,
	links[]{
		_key,
		title,
		url,
		description
	}
}`;

const sectionDocuments = await sanityClient.fetch<UsefulLinkSection[]>(USEFUL_LINK_SECTIONS_QUERY);

const sectionColorClassMap: Record<UsefulLinkSectionColor, string> = {
	green: 'from-green-100 to-green-200 ring-green-300',
	amber: 'from-amber-100 to-amber-200 ring-amber-300',
	sky: 'from-sky-100 to-blue-200 ring-blue-300',
	violet: 'from-violet-100 to-fuchsia-100 ring-violet-300',
	rose: 'from-rose-100 to-pink-100 ring-pink-300',
	gray: 'from-gray-100 to-gray-200 ring-gray-300',
};

const sections = sectionDocuments.filter(
	(section): section is UsefulLinkSection =>
		Boolean(
			section?.title &&
				section?.icon &&
				section?.color &&
				Array.isArray(section?.links) &&
				section.links.length
		)
);

function getSectionId(title: string) {
	return title
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '');
}
---

<SiteLayout title="Useful Links">
	<div class="space-y-8">
		<PageIntro
			title="Useful Links"
			description="A curated collection of websites, guides, videos, and practical resources to support your growing journey."
			pills={[
				{
					label: `${sections.length} resource collection${sections.length === 1 ? '' : 's'}`,
					icon: LibraryBig,
					iconClass: 'text-green-700',
				},
				{
					label: 'Growing, tools, and preserving',
					icon: Leaf,
					iconClass: 'text-sky-700',
				},
				{
					label: 'Community and learning links',
					icon: Users,
					iconClass: 'text-amber-600',
				},
			]}
		/>

		{
			sections.length ? (
				<div class="space-y-0">
					{
						sections.map((section, index) => {
							const Icon = projectIconMap[section.icon] ?? projectIconMap.leaf;
							const isSiteBackgroundSection = index % 2 === 1;
							const cardClass = sectionColorClassMap[section.color] ?? sectionColorClassMap.green;

							return (
								<FullBleedSection
									class="bleed-mobile-only py-8"
									bleedClass={isSiteBackgroundSection ? '' : 'bleed-white-70'}
								>
									<article
										id={getSectionId(section.title)}
										class="px-1 py-2 sm:rounded-4xl sm:bg-white sm:p-8 sm:shadow-xl sm:ring-1 sm:ring-gray-100"
									>
										<div class="flex items-center gap-4">
											<div
												class:list={[
													'flex h-12 w-12 items-center justify-center rounded-full bg-linear-to-br ring-1',
													cardClass,
												]}
											>
												<Icon class="h-6 w-6 text-green-800" />
											</div>
											<h2 class="text-2xl font-bold tracking-tight text-gray-900">
												{section.title}
											</h2>
										</div>

										<div class="mt-6 grid gap-4 md:grid-cols-2">
											{
												section.links.map((link) => {
													const isExternal = link.url.startsWith('http');

													return (
														<a
															href={link.url}
															target={isExternal ? '_blank' : undefined}
															rel={isExternal ? 'noopener noreferrer' : undefined}
															class="group flex items-start gap-3 rounded-3xl bg-gray-50 p-4 transition hover:bg-green-50"
														>
															<ExternalLink class="mt-0.5 h-5 w-5 shrink-0 text-green-800 transition group-hover:scale-110" />
															<div class="min-w-0 flex-1">
																<h3 class="font-semibold text-gray-900 transition group-hover:text-green-800">
																	{link.title}
																</h3>
																<p class="mt-1 text-sm leading-6 text-gray-600">
																	{link.description}
																</p>
															</div>
														</a>
													);
												})
											}
										</div>
									</article>
								</FullBleedSection>
							);
						})
					}
				</div>
			) : (
				<FullBleedSection class="py-12" bleedClass="bleed-white-70">
					<div class="rounded-4xl border border-dashed border-gray-300 bg-white/80 p-8 text-center text-gray-600">
						Add some `Useful Link Section` documents in Sanity Studio and they will appear here.
					</div>
				</FullBleedSection>
			)
		}

		<section id="suggest-resource" class="rounded-4xl bg-[#2d5016] px-6 py-8 text-center text-white shadow-2xl sm:px-8 sm:py-10">
			<div class="mx-auto max-w-3xl">
				<h2 class="text-2xl font-bold tracking-tight">Know a Great Resource?</h2>
				<p class="mt-3 leading-8 text-green-50">
					Help us build a stronger collection of growing resources by sharing useful
					websites, videos, books, or tools that others in the community might benefit from.
				</p>
				<a
					href="/contact"
					class="mt-6 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 font-semibold text-[#2d5016] transition hover:bg-green-50"
				>
					Suggest a Resource
				</a>
			</div>
		</section>
	</div>
</SiteLayout>
