---
import SiteLayout from '../layouts/SiteLayout.astro';
import Container from '../components/Container.astro';
import FullBleedSection from '../components/FullBleedSection.astro';
import {
	ArrowRight,
	BookOpen,
	Check,
	Leaf,
	Sprout,
	Users,
} from '@lucide/astro';

const stats = [
	{ value: '150+', label: 'Active Members' },
	{ value: '12', label: 'Community Plots' },
	{ value: '40+', label: 'Events/Year' },
] as const;

const featureCards = [
	{
		title: 'Community Allotments',
		description:
			'Access shared growing spaces where members cultivate produce and learn sustainable practices together.',
		href: '/projects',
		linkLabel: 'Learn more',
		icon: Sprout,
		iconClass: 'from-green-400 to-green-600',
	},
	{
		title: 'Workshops & Events',
		description:
			'Join regular workshops, seasonal celebrations, and community gatherings throughout the year.',
		href: '/calendar',
		linkLabel: 'View calendar',
		icon: Users,
		iconClass: 'from-blue-400 to-blue-600',
	},
	{
		title: 'Shared Knowledge',
		description:
			'Access recipes, growing tips, and preservation techniques from experienced members.',
		href: '/newsletter',
		linkLabel: 'Browse resources',
		icon: BookOpen,
		iconClass: 'from-amber-400 to-amber-600',
	},
] as const;

const aboutPoints = [
	{
		title: 'Beginner Friendly',
		description: 'No experience needed - we support growers at every level',
	},
	{
		title: 'Sustainable Practices',
		description: 'Learn organic, chemical-free growing methods',
	},
	{
		title: 'Strong Community',
		description: 'Connect with like-minded neighbors and make friends',
	},
] as const;

const galleryItems = [
	{
		title: 'Fresh Harvests',
		description: 'Organic vegetables grown by our members',
		src: 'https://images.unsplash.com/photo-1632918364721-2fb4a81e0879?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxmcmVzaCUyMGhhcnZlc3RlZCUyMHZlZ2V0YWJsZXMlMjBjbG9zZXVwfGVufDF8fHx8MTc3NDAzMDYxOXww&ixlib=rb-4.1.0&q=80&w=1080',
		alt: 'Fresh harvested vegetables',
	},
	{
		title: 'Thriving Gardens',
		description: 'Beautiful, sustainable growing spaces',
		src: 'https://images.unsplash.com/photo-1715764338356-ddfc0341702f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxncmVlbiUyMGxlYWZ5JTIwZ2FyZGVuJTIwbmF0dXJlfGVufDF8fHx8MTc3NDAzMDYxOXww&ixlib=rb-4.1.0&q=80&w=1080',
		alt: 'Leafy green garden',
	},
] as const;
---

<SiteLayout title="Home" mainClass="px-0 py-0" wrapContent={false}>
	<div class="bg-[#f5f8ef]">
		<section class="relative overflow-hidden bg-[#f5f8ef] text-gray-900">
			<Container class="relative py-20 lg:py-32">
				<div class="grid items-center gap-12 lg:grid-cols-2">
					<div class="space-y-8">
						<div class="inline-flex items-center gap-2 rounded-full bg-white/90 px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-gray-200 backdrop-blur-sm">
							<Leaf class="h-4 w-4 text-green-700" />
							<span>Growing Together Since 2020</span>
						</div>

						<div class="space-y-6">
							<h1 class="text-5xl font-bold leading-tight lg:text-6xl">
								Cultivating Community Through
								<span class="block text-[#2d5016]">Sustainable Growing</span>
							</h1>

							<p class="max-w-xl text-xl leading-relaxed text-gray-600">
								Join Chopwell&apos;s vibrant community of food growers. Share knowledge,
								harvest fresh produce, and build lasting connections.
							</p>
						</div>

						<div class="flex flex-col gap-4 sm:flex-row">
							<a
								href="/get-involved"
								class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-8 py-4 font-semibold text-[#2d5016] shadow-xl transition-all hover:scale-105 hover:bg-green-50 hover:shadow-2xl"
							>
								<span>Get Started Today</span>
								<ArrowRight class="h-5 w-5" />
							</a>
							<a
								href="/projects"
								class="inline-flex items-center justify-center rounded-full border-2 border-[#2d5016]/20 px-8 py-4 font-semibold text-[#2d5016] backdrop-blur-sm transition-all hover:bg-white/60"
							>
								Learn More
							</a>
						</div>

						<div class="flex flex-wrap items-center gap-6 pt-4 sm:gap-8">
							{
								stats.map((item, index) => (
									<div
										class:list={[
											'pr-0 sm:pr-8',
											index < stats.length - 1
												? 'sm:border-r sm:border-white/30'
												: '',
										]}
									>
										<div class="text-3xl font-bold">{item.value}</div>
										<div class="text-sm text-gray-500">{item.label}</div>
									</div>
								))
							}
						</div>
					</div>

					<div class="relative">
						<div class="relative overflow-hidden rounded-2xl shadow-2xl">
							<img
								src="https://images.unsplash.com/photo-1764001032216-360a43576788?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjb21tdW5pdHklMjBnYXJkZW4lMjBmcmVzaCUyMHZlZ2V0YWJsZXN8ZW58MXx8fHwxNzc0MDMwNjE4fDA&ixlib=rb-4.1.0&q=80&w=1080"
								alt="Community garden with fresh vegetables"
								width="1080"
								height="720"
								class="h-125 w-full object-cover"
								loading="eager"
								decoding="async"
							/>
							<div class="absolute inset-0 bg-linear-to-t from-black/10 to-transparent"></div>
						</div>

						<div class="absolute -bottom-6 left-4 right-4 rounded-xl bg-white p-6 shadow-2xl sm:-left-6 sm:right-auto sm:max-w-xs">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100">
									<Check class="h-6 w-6 text-[#2d5016]" />
								</div>
								<div>
									<div class="font-bold text-gray-900">Organic &amp; Sustainable</div>
									<div class="text-sm text-gray-600">100% chemical-free growing</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</Container>
		</section>

		<FullBleedSection class="z-10 py-12" bleedClass="bleed-white-70">
			<div class="grid gap-6 md:grid-cols-3 lg:gap-8">
				{
					featureCards.map((card) => {
						const Icon = card.icon;

						return (
							<div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-xl transition-all hover:-translate-y-1 hover:shadow-2xl">
								<div
									class:list={[
										'mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-linear-to-br shadow-lg',
										card.iconClass,
									]}
								>
									<Icon class="h-7 w-7 text-white" />
								</div>
								<h2 class="mb-3 text-2xl font-bold text-gray-900">{card.title}</h2>
								<p class="mb-6 leading-relaxed text-gray-600">{card.description}</p>
								<a
									href={card.href}
									class="group inline-flex items-center gap-1 font-semibold text-[#2d5016] transition-all hover:gap-2"
								>
									<span>{card.linkLabel}</span>
									<ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
								</a>
							</div>
						);
					})
				}
			</div>
		</FullBleedSection>

		<section class="py-24">
			<Container>
				<div class="grid items-center gap-16 lg:grid-cols-2">
					<div class="order-2 lg:order-1">
						<div class="mb-6 inline-block rounded-full bg-green-50 px-4 py-2 text-sm font-semibold text-[#2d5016]">
							About Our Community
						</div>
						<h2 class="mb-6 text-4xl leading-tight font-bold text-gray-900 lg:text-5xl">
							Growing More Than Just Vegetables
						</h2>
						<div class="space-y-4 text-lg leading-relaxed text-gray-600">
							<p>
								Chopwell Community Food Growers brings together local residents who share
								a passion for sustainable food production, environmental stewardship, and
								community connection.
							</p>
							<p>
								From our community allotments to backyard growing projects and food
								preservation workshops, we&apos;re building resilience and fostering
								friendships through hands-on growing experiences.
							</p>
						</div>

						<div class="mt-8 space-y-4">
							{
								aboutPoints.map((point) => (
									<div class="flex items-start gap-4">
										<div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-100">
											<Check class="h-4 w-4 text-[#2d5016]" />
										</div>
										<div>
											<div class="mb-1 font-semibold text-gray-900">{point.title}</div>
											<div class="text-gray-600">{point.description}</div>
										</div>
									</div>
								))
							}
						</div>
					</div>

					<div class="relative order-1 lg:order-2">
						<div class="relative overflow-hidden rounded-2xl shadow-2xl">
							<img
								src="https://images.unsplash.com/photo-1583335554751-fa66e066691a?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxwZW9wbGUlMjBnYXJkZW5pbmclMjB0b2dldGhlciUyMGFsbG90bWVudHxlbnwxfHx8fDE3NzQwMzA2MTl8MA&ixlib=rb-4.1.0&q=80&w=1080"
								alt="People gardening together at an allotment"
								width="1080"
								height="720"
								class="h-150 w-full object-cover"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="absolute -bottom-8 -right-8 -z-10 hidden h-64 w-64 rounded-2xl bg-green-100 lg:block"></div>
					</div>
				</div>
			</Container>
		</section>

		<FullBleedSection class="py-24" bleedClass="bleed-gray-50">
			<div class="mb-16 text-center">
				<h2 class="mb-4 text-4xl font-bold text-gray-900">See Our Community in Action</h2>
				<p class="mx-auto max-w-2xl text-xl text-gray-600">
					From seed to harvest, experience the journey of growing together
				</p>
			</div>

			<div class="grid gap-6 md:grid-cols-2">
				{
					galleryItems.map((item) => (
						<div class="group relative h-80 overflow-hidden rounded-2xl shadow-lg">
							<img
								src={item.src}
								alt={item.alt}
								width="1080"
								height="720"
								class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
								loading="lazy"
								decoding="async"
							/>
							<div class="absolute inset-0 flex items-end bg-linear-to-t from-black/60 to-transparent p-8">
								<div class="text-white">
									<h3 class="mb-2 text-2xl font-bold">{item.title}</h3>
									<p class="text-gray-200">{item.description}</p>
								</div>
							</div>
						</div>
					))
				}
			</div>
		</FullBleedSection>

		<section class="py-24">
			<Container>
				<div class="relative overflow-hidden rounded-3xl bg-[#2d5016] p-12 text-center text-white lg:p-16">
					<div class="relative z-10 mx-auto max-w-3xl">
						<h2 class="mb-6 text-4xl font-bold lg:text-5xl">Ready to Start Growing?</h2>
						<p class="mb-8 text-xl leading-relaxed text-green-50">
							Join our vibrant community today and discover the joy of growing your own
							food, making new friends, and contributing to a sustainable future.
						</p>
						<div class="flex flex-col justify-center gap-4 sm:flex-row">
							<a
								href="/get-involved"
								class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 font-semibold text-[#2d5016] shadow-xl transition-all hover:scale-105 hover:bg-green-50 hover:shadow-2xl"
							>
								Get Involved Today
							</a>
							<a
								href="/contact"
								class="inline-flex items-center justify-center rounded-full border-2 border-white px-8 py-4 font-semibold text-white transition-all hover:bg-white/10"
							>
								Contact Us
							</a>
						</div>
					</div>
				</div>
			</Container>
		</section>
	</div>
</SiteLayout>
