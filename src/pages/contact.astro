---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageIntro from '../components/PageIntro.astro';
import {
	Clock3,
	Mail,
	MapPin,
	Phone,
} from '@lucide/astro';

const contactDetails = [
	{
		title: 'Email',
		icon: 'mail',
		content: 'info@chopwellgrowers.org',
		href: 'mailto:info@chopwellgrowers.org',
		extra: '',
	},
	{
		title: 'Phone',
		icon: 'phone',
		content: '01234 567 890',
		href: 'tel:01234567890',
		extra: 'Mon-Fri, 9am-5pm',
	},
	{
		title: 'Location',
		icon: 'map-pin',
		content: 'Community Allotment Site\nGreen Lane\nChopwell\nNE17 7XX',
		href: '',
		extra: '',
	},
] as const;

const socialLinks = [
	{ label: 'Facebook', href: '#', shortLabel: 'Fb' },
	{ label: 'Instagram', href: '#', shortLabel: 'Ig' },
	{ label: 'Twitter', href: '#', shortLabel: 'X' },
] as const;

const accessHours = [
	{ day: 'Monday - Friday', hours: 'Dawn - Dusk' },
	{ day: 'Saturday', hours: '8am - 6pm' },
	{ day: 'Sunday', hours: '9am - 5pm' },
] as const;

const faqLinks = [
	{
		title: 'How do I join?',
		description: 'Learn about membership and getting started.',
		href: '/get-involved',
	},
	{
		title: 'Are plots available?',
		description: 'Check current plot availability and the waiting list.',
		href: '/projects/community-allotment',
	},
	{
		title: 'What are the costs?',
		description: 'Read more about membership fees and plot rental information.',
		href: '/get-involved',
	},
	{
		title: 'Can I visit first?',
		description: 'Arrange a site visit and meet current members.',
		href: '/contact',
	},
] as const;

const iconMap = {
	mail: Mail,
	phone: Phone,
	'map-pin': MapPin,
};
---

<SiteLayout title="Contact">
	<div class="space-y-8">
		<PageIntro
			title="Contact Us"
			description="Get in touch with Chopwell Community Food Growers and let us know how we can help."
			pills={[
				{ label: 'Email us directly', icon: Mail, iconClass: 'text-green-700' },
				{ label: 'Community allotment site', icon: MapPin, iconClass: 'text-sky-700' },
				{ label: 'Visits available all week', icon: Clock3, iconClass: 'text-amber-600' },
			]}
		/>

		<section class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-white/70 py-12">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="grid items-stretch gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]">
					<div>
						<section class="h-full rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 sm:p-8">
							<h2 class="text-2xl font-bold tracking-tight text-gray-900">Get in Touch</h2>
							<div class="mt-6 space-y-5">
								{
									contactDetails.map((item) => {
										const Icon = iconMap[item.icon];

										return (
											<div class="flex items-start gap-4">
												<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-green-100 text-green-800">
													<Icon class="h-6 w-6" />
												</div>
												<div>
													<h3 class="font-semibold text-gray-900">{item.title}</h3>
													{
														item.href ? (
															<a
																href={item.href}
																class="mt-1 inline-block text-green-800 transition hover:underline"
															>
																{item.content}
															</a>
														) : (
															<p class="mt-1 whitespace-pre-line text-gray-700">{item.content}</p>
														)
													}
													{
														item.extra ? (
															<p class="mt-1 text-sm text-gray-600">{item.extra}</p>
														) : null
													}
												</div>
											</div>
										);
									})
								}
							</div>
						</section>
					</div>

					<div class="space-y-6">
						<section class="rounded-4xl bg-[#2d5016] p-6 text-white shadow-xl sm:p-8">
							<h2 class="text-xl font-bold tracking-tight">Follow Us</h2>
							<p class="mt-3 leading-7 text-green-50">
								Stay connected on social media for updates, photos, and seasonal tips.
							</p>
							<div class="mt-5 flex gap-3">
								{
									socialLinks.map((link) => (
										<a
											href={link.href}
											aria-label={link.label}
											class="flex h-12 w-12 items-center justify-center rounded-full bg-white/15 text-sm font-semibold text-white transition hover:bg-white/25"
										>
											{link.shortLabel}
										</a>
									))
								}
							</div>
						</section>

						<section class="rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 sm:p-8">
							<h2 class="text-xl font-bold tracking-tight text-gray-900">Site Access Hours</h2>
							<div class="mt-5 space-y-3 text-gray-700">
								{
									accessHours.map((entry) => (
										<div class="flex items-center justify-between gap-4">
											<span class="font-semibold">{entry.day}</span>
											<span>{entry.hours}</span>
										</div>
									))
								}
							</div>
						</section>
					</div>
				</div>
			</div>
		</section>

		<section class="rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 sm:p-8">
			<h2 class="text-2xl font-bold tracking-tight text-gray-900">
				Frequently Asked Questions
			</h2>
			<div class="mt-5 grid gap-4 md:grid-cols-2">
				{
					faqLinks.map((item) => (
						<a href={item.href} class="rounded-3xl bg-green-50 p-4 text-left transition hover:shadow-md">
							<h3 class="font-semibold text-green-800">{item.title}</h3>
							<p class="mt-1 text-sm leading-6 text-gray-600">{item.description}</p>
						</a>
					))
				}
			</div>
		</section>
	</div>
</SiteLayout>
