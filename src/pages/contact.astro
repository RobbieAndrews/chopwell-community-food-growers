---
import SiteLayout from '../layouts/SiteLayout.astro';
import FullBleedSection from '../components/FullBleedSection.astro';
import PageIntro from '../components/PageIntro.astro';
import SocialPlatformIcon from '../components/SocialPlatformIcon.astro';
import {
	Clock3,
	Mail,
	MapPin,
	Phone,
} from '@lucide/astro';
import { sanityClient } from 'sanity:client';

interface ContactAccessHour {
	_key?: string;
	label: string;
	hours: string;
}

interface ContactSocialLink {
	_key?: string;
	platform: string;
	label?: string;
	url: string;
}

interface ContactFaqItem {
	_key?: string;
	question: string;
	answer: string;
}

interface ContactPageDocument {
	emailAddress?: string;
	phoneNumber?: string;
	phoneAvailability?: string;
	location?: string;
	accessHours?: ContactAccessHour[];
	socialLinks?: ContactSocialLink[];
	faqItems?: ContactFaqItem[];
}

const CONTACT_PAGE_QUERY = `*[
	_type == "contactPage"
]|order(_updatedAt desc)[0]{
	emailAddress,
	phoneNumber,
	phoneAvailability,
	location,
	accessHours[]{
		_key,
		label,
		hours
	},
	socialLinks[]{
		_key,
		platform,
		label,
		url
	},
	faqItems[]{
		_key,
		question,
		answer
	}
}`;

const contactPage = await sanityClient.fetch<ContactPageDocument | null>(CONTACT_PAGE_QUERY);

const contactDetails = [
	{
		title: 'Email',
		icon: 'mail',
		content: contactPage?.emailAddress ?? '',
		href: contactPage?.emailAddress ? `mailto:${contactPage.emailAddress}` : '',
		extra: '',
	},
	{
		title: 'Phone',
		icon: 'phone',
		content: contactPage?.phoneNumber ?? '',
		href: contactPage?.phoneNumber
			? `tel:${contactPage.phoneNumber.replace(/[^+\d]/g, '')}`
			: '',
		extra: contactPage?.phoneAvailability ?? '',
	},
	{
		title: 'Location',
		icon: 'map-pin',
		content: contactPage?.location ?? '',
		href: '',
		extra: '',
	},
].filter((item) => item.content) as Array<{
	title: string;
	icon: 'mail' | 'phone' | 'map-pin';
	content: string;
	href: string;
	extra: string;
}>;

const socialLinks = (contactPage?.socialLinks ?? []).filter(
	(link): link is ContactSocialLink => Boolean(link?.url && (link?.label || link?.platform))
);

const accessHours = (contactPage?.accessHours ?? []).filter(
	(entry): entry is ContactAccessHour => Boolean(entry?.label && entry?.hours)
);

const faqItems = (contactPage?.faqItems ?? []).filter(
	(item): item is ContactFaqItem => Boolean(item?.question && item?.answer)
);

const iconMap = {
	mail: Mail,
	phone: Phone,
	'map-pin': MapPin,
};

function getSocialLabel(link: ContactSocialLink) {
	if (link.label) return link.label;

	switch (link.platform) {
		case 'facebook':
			return 'Facebook';
		case 'instagram':
			return 'Instagram';
		case 'x':
			return 'X';
		case 'linkedin':
			return 'LinkedIn';
		case 'youtube':
			return 'YouTube';
		case 'tiktok':
			return 'TikTok';
		case 'bluesky':
			return 'Bluesky';
		case 'website':
			return 'Website';
		default:
			return 'Social';
	}
}

function getSocialShortLabel(link: ContactSocialLink) {
	switch (link.platform) {
		case 'x':
			return 'X';
		case 'tiktok':
			return 'Tk';
		case 'bluesky':
			return 'Bs';
		default:
			return (link.label ?? 'So').slice(0, 3);
	}
}

function getSocialBadgeClass(platform: string) {
	switch (platform) {
		case 'facebook':
			return 'bg-[#4267B2] hover:bg-[#3d5fa5]';
		case 'instagram':
			return 'bg-[linear-gradient(135deg,#405DE6_0%,#833AB4_28%,#C13584_52%,#FD1D1D_76%,#FCAF45_100%)] hover:brightness-105';
		case 'x':
			return 'bg-[#2f2f2f] hover:bg-[#272727]';
		case 'linkedin':
			return 'bg-[#1da1dc] hover:bg-[#1895cb]';
		case 'youtube':
			return 'bg-[#ff2d2d] hover:bg-[#ef2929]';
		case 'tiktok':
			return 'bg-[#2f2f2f] hover:bg-[#272727]';
		case 'bluesky':
			return 'bg-[#22a9e8] hover:bg-[#1c9cd7]';
		case 'website':
			return 'bg-[#facc15] hover:bg-[#eab308]';
		default:
			return 'bg-white/15 hover:bg-white/25';
	}
}

---

<SiteLayout title="Contact">
	<div class="space-y-8">
		<PageIntro
			title="Contact Us"
			description="Get in touch with Chopwell Community Food Growers and let us know how we can help."
			pills={[
				{ label: 'Email us directly', icon: Mail, iconClass: 'text-green-700' },
				{ label: 'Community allotment site', icon: MapPin, iconClass: 'text-sky-700' },
				{ label: 'Visits available all week', icon: Clock3, iconClass: 'text-amber-600' },
			]}
		/>

		<FullBleedSection class="py-12" bleedClass="bleed-white-70">
			<div class="grid items-stretch gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]">
				<div>
					<section class="h-full rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 sm:p-8">
						<h2 class="text-2xl font-bold tracking-tight text-gray-900">Get in Touch</h2>
						{
							contactDetails.length ? (
								<div class="mt-6 space-y-5">
									{
										contactDetails.map((item) => {
											const Icon = iconMap[item.icon];

											return (
												<div class="flex items-start gap-4">
													<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-green-100 text-green-800">
														<Icon class="h-6 w-6" />
													</div>
													<div>
														<h3 class="font-semibold text-gray-900">{item.title}</h3>
														{
															item.href ? (
																<a
																	href={item.href}
																	class="mt-1 inline-block text-green-800 transition hover:underline"
																>
																	{item.content}
																</a>
															) : (
																<p class="mt-1 whitespace-pre-line text-gray-700">{item.content}</p>
															)
														}
														{
															item.extra ? (
																<p class="mt-1 text-sm text-gray-600">{item.extra}</p>
															) : null
														}
													</div>
												</div>
											);
										})
									}
								</div>
							) : (
								<div class="mt-6 rounded-3xl border border-dashed border-gray-300 bg-gray-50 p-6 text-gray-600">
									No Contact details added yet
								</div>
							)
						}
					</section>
				</div>

				<div class="space-y-6">
					<section class="rounded-4xl bg-[#2d5016] p-6 text-white shadow-xl sm:p-8">
						<h2 class="text-xl font-bold tracking-tight">Follow Us</h2>
						<p class="mt-3 leading-7 text-green-50">
							Stay connected on social media for updates, photos, and seasonal tips.
						</p>
						{
							socialLinks.length ? (
								<div class="mt-5 flex flex-wrap gap-3">
									{
										socialLinks.map((link) => (
											<a
												href={link.url}
												target="_blank"
												rel="noopener noreferrer"
												aria-label={getSocialLabel(link)}
												class:list={[
													'flex h-10 w-10 items-center justify-center rounded-full text-base font-semibold text-white transition will-change-transform hover:-translate-y-0.5',
													getSocialBadgeClass(link.platform),
												]}
											>
												{
													link.platform === 'other' ? (
														<span>{getSocialShortLabel(link)}</span>
													) : (
														<span class="flex items-center justify-center">
															<SocialPlatformIcon
																platform={link.platform}
																class="h-8 w-8"
															/>
														</span>
													)
												}
											</a>
										))
									}
								</div>
							) : (
								<p class="mt-5 text-sm text-green-50/90">No social links added yet.</p>
							)
						}
					</section>

					<section class="rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 sm:p-8">
						<h2 class="text-xl font-bold tracking-tight text-gray-900">Site Access Hours</h2>
						{
							accessHours.length ? (
								<div class="mt-5 space-y-3 text-gray-700">
									{
										accessHours.map((entry) => (
											<div class="flex items-center justify-between gap-4">
												<span class="font-semibold">{entry.label}</span>
												<span>{entry.hours}</span>
											</div>
										))
									}
								</div>
							) : (
								<p class="mt-5 text-gray-600">No access hours added yet.</p>
							)
						}
					</section>
				</div>
			</div>
		</FullBleedSection>

		<section class="rounded-4xl bg-white p-6 shadow-xl ring-1 ring-gray-100 sm:p-8">
			<h2 class="text-2xl font-bold tracking-tight text-gray-900">
				Frequently Asked Questions
			</h2>
			{
				faqItems.length ? (
					<div class="mt-5 grid gap-4 md:grid-cols-2">
						{
							faqItems.map((item) => (
								<article class="rounded-3xl bg-green-50 p-4">
									<h3 class="font-semibold text-green-800">{item.question}</h3>
									<p class="mt-1 text-sm leading-6 text-gray-600">{item.answer}</p>
								</article>
							))
						}
					</div>
				) : (
					<p class="mt-5 text-gray-600">No FAQ items added yet.</p>
				)
			}
		</section>
	</div>
</SiteLayout>
