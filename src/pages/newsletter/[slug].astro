---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { ArrowLeft, Archive } from '@lucide/astro';
import { newsletters, type Newsletter } from '../../data/newsletters';

export function getStaticPaths() {
	return newsletters.map((newsletter) => ({
		params: { slug: newsletter.slug },
		props: { newsletter },
	}));
}

interface Props {
	newsletter: Newsletter;
}

const { newsletter } = Astro.props;
---

<SiteLayout title={newsletter.title}>
	<div class="space-y-8">
		<a
			href="/newsletter"
			class="inline-flex items-center gap-2 rounded-full bg-stone-100 px-4 py-2 text-sm font-semibold text-stone-700 transition hover:bg-stone-200"
		>
			<ArrowLeft class="h-4 w-4" />
			<span>Back to newsletter</span>
		</a>

		<section class="rounded-4xl bg-linear-to-br from-stone-50 via-lime-50/70 to-emerald-100/60 px-6 py-8 sm:px-8 sm:py-12">
			<div class="max-w-3xl">
				<div class="flex items-center gap-3 text-green-800">
					<Archive class="h-6 w-6" />
					<p class="text-sm font-semibold uppercase tracking-[0.18em]">{newsletter.date}</p>
				</div>
				<h1 class="mt-4 text-4xl font-bold tracking-tight text-stone-900 sm:text-5xl">
					{newsletter.title}
				</h1>
				<p class="mt-4 max-w-2xl text-lg leading-8 text-stone-700">
					{newsletter.intro}
				</p>
				<ul class="mt-5 flex flex-wrap gap-2">
					{
						newsletter.topics.map((topic) => (
							<li class="rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-800">
								{topic}
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
			<div class="rounded-4xl border border-stone-200 bg-white p-6 shadow-sm sm:p-8">
				<h2 class="text-2xl font-bold tracking-tight text-stone-900">This Edition</h2>
				<div class="mt-5 space-y-6">
					{
						newsletter.sections.map((section) => (
							<article>
								<h3 class="text-xl font-bold tracking-tight text-stone-900">
									{section.title}
								</h3>
								<p class="mt-3 leading-8 text-stone-700">{section.body}</p>
							</article>
						))
					}
				</div>
			</div>

			<div class="rounded-4xl border border-green-700 bg-green-50 p-6 sm:p-8">
				<h2 class="text-2xl font-bold tracking-tight text-stone-900">Newsletter Notes</h2>
				<p class="mt-4 leading-8 text-stone-700">
					This page is generated from a shared newsletter data source. As you add or
					remove editions, the archive and the individual edition pages stay in sync.
				</p>
				<p class="mt-4 leading-8 text-stone-700">
					When you later move this content into a CMS, the same `slug` pattern can drive
					these pages automatically.
				</p>
			</div>
		</section>
	</div>
</SiteLayout>
