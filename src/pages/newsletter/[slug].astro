---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { ArrowLeft, Archive } from '@lucide/astro';
import { PortableText } from 'astro-portabletext';
import type { TypedObject } from 'astro-portabletext/types';
import { sanityClient } from 'sanity:client';
import NewsletterBlockquote from '../../components/newsletter/NewsletterBlockquote.astro';
import NewsletterBodyImage from '../../components/newsletter/NewsletterBodyImage.astro';
import NewsletterBulletList from '../../components/newsletter/NewsletterBulletList.astro';
import NewsletterCallout from '../../components/newsletter/NewsletterCallout.astro';
import NewsletterHeadingThree from '../../components/newsletter/NewsletterHeadingThree.astro';
import NewsletterHeadingTwo from '../../components/newsletter/NewsletterHeadingTwo.astro';
import NewsletterListItem from '../../components/newsletter/NewsletterListItem.astro';
import NewsletterNumberList from '../../components/newsletter/NewsletterNumberList.astro';
import NewsletterParagraph from '../../components/newsletter/NewsletterParagraph.astro';
import { urlForImage, type SanityImageWithAlt } from '../../lib/sanity';

export function getStaticPaths() {
	const NEWSLETTER_SLUGS_QUERY = `*[
		_type == "newsletterIssue"
		&& defined(slug.current)
	]{
		"params": { "slug": slug.current }
	}`;

	return sanityClient.fetch(NEWSLETTER_SLUGS_QUERY);
}

interface NewsletterCalloutBlock extends TypedObject {
	_type: 'newsletterCallout';
	quote: string;
	attribution?: string;
}

interface NewsletterPage {
	_id: string;
	title: string;
	slug: { current: string };
	publishedAt: string;
	excerpt: string;
	topics?: string[];
	leadStoryTitle: string;
	leadStoryIntro: string;
	heroImage?: SanityImageWithAlt;
	content?: (TypedObject | NewsletterCalloutBlock)[];
}

const NEWSLETTER_QUERY = `*[
	_type == "newsletterIssue"
	&& slug.current == $slug
][0]{
	_id,
	title,
	slug,
	publishedAt,
	excerpt,
	topics,
	leadStoryTitle,
	leadStoryIntro,
	heroImage,
	content
}`;

const { slug } = Astro.params as { slug: string };

const newsletter = await sanityClient.fetch<NewsletterPage | null>(NEWSLETTER_QUERY, {
	slug,
});

if (!newsletter) {
	return Astro.redirect('/newsletter');
}

const newsletterImageUrl = newsletter.heroImage
	? urlForImage(newsletter.heroImage)?.width(1400).height(900).fit('crop').url()
	: null;
const newsletterImageAlt = newsletter.heroImage?.alt || newsletter.title;
const publishedDate = new Intl.DateTimeFormat('en-GB', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(new Date(newsletter.publishedAt));

const portableTextComponents = {
	type: {
		newsletterBodyImage: NewsletterBodyImage,
		newsletterCallout: NewsletterCallout,
	},
	block: {
		normal: NewsletterParagraph,
		h2: NewsletterHeadingTwo,
		h3: NewsletterHeadingThree,
		blockquote: NewsletterBlockquote,
	},
	list: {
		bullet: NewsletterBulletList,
		number: NewsletterNumberList,
	},
	listItem: {
		bullet: NewsletterListItem,
		number: NewsletterListItem,
	},
};
---

<SiteLayout title={newsletter.title}>
	<div class="space-y-8">
		<a
			href="/newsletter"
			class="inline-flex items-center gap-2 rounded-full bg-stone-100 px-4 py-2 text-sm font-semibold text-stone-700 transition hover:bg-stone-200"
		>
			<ArrowLeft class="h-4 w-4" />
			<span>Back to newsletter</span>
		</a>

		<section class="overflow-hidden rounded-4xl border border-stone-200 bg-white shadow-sm">
			<div class="grid gap-0 lg:grid-cols-[1.05fr_0.95fr]">
				<div class="flex flex-col justify-center px-6 py-8 sm:px-8 sm:py-10 lg:px-10">
					<div class="flex items-center gap-3 text-green-800">
						<Archive class="h-6 w-6" />
						<p class="text-sm font-semibold uppercase tracking-[0.18em]">{publishedDate}</p>
					</div>
					<h1 class="mt-4 text-4xl font-bold tracking-tight text-stone-900 sm:text-5xl">
						{newsletter.title}
					</h1>
					<p class="mt-4 max-w-2xl text-lg leading-8 text-stone-700">
						{newsletter.excerpt}
					</p>
					{
						newsletter.topics?.length ? (
							<ul class="mt-5 flex flex-wrap gap-2">
								{
									newsletter.topics.map((topic) => (
										<li class="rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-800">
											{topic}
										</li>
									))
								}
							</ul>
						) : null
					}
				</div>

				<div class="min-h-full">
					{
						newsletterImageUrl ? (
							<img
								src={newsletterImageUrl}
								alt={newsletterImageAlt}
								loading="lazy"
								class="h-full min-h-72 w-full object-cover"
							/>
						) : (
							<div class="flex h-full min-h-72 items-center justify-center bg-linear-to-br from-lime-100 via-stone-50 to-emerald-100 text-green-900">
								<Archive class="h-16 w-16" />
							</div>
						)
					}
				</div>
			</div>
		</section>

		<section>
			<div class="rounded-4xl border border-stone-200 bg-white p-6 shadow-sm sm:p-8 lg:p-10">
				<h2 class="mt-3 text-3xl font-bold tracking-tight text-stone-900">
					{newsletter.leadStoryTitle}
				</h2>
				<p class="mt-4 text-lg leading-8 text-stone-700">{newsletter.leadStoryIntro}</p>

				{
					Array.isArray(newsletter.content) && newsletter.content.length ? (
						<div class="mt-8 max-w-4xl">
							<PortableText value={newsletter.content} components={portableTextComponents} />
						</div>
					) : (
						<p class="mt-8 text-base leading-8 text-stone-700">
							Story content can be added in Sanity whenever you are ready. This issue is
							currently showing its hero details and lead story introduction.
						</p>
					)
				}
			</div>
		</section>
	</div>
</SiteLayout>
