---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { ArrowLeft, Archive } from '@lucide/astro';
import { PortableText } from 'astro-portabletext';
import { sanityClient } from 'sanity:client';
import ContentFeatureCard from '../../components/ContentFeatureCard.astro';
import {
	articlePortableTextComponents,
	type ArticlePortableTextBlock,
} from '../../lib/articlePortableText';
import {
	getSanityImageSrcSet,
	getSanityImageUrl,
	type SanityImageWithAlt,
} from '../../lib/sanity';

export function getStaticPaths() {
	const NEWSLETTER_SLUGS_QUERY = `*[
		_type == "newsletterIssue"
		&& defined(slug.current)
	]{
		"params": { "slug": slug.current }
	}`;

	return sanityClient.fetch(NEWSLETTER_SLUGS_QUERY);
}

interface NewsletterPage {
	_id: string;
	title: string;
	slug: { current: string };
	publishedAt: string;
	excerpt: string;
	topics?: string[];
	leadStoryTitle: string;
	leadStoryIntro: string;
	heroImage?: SanityImageWithAlt;
	content?: ArticlePortableTextBlock[];
}

const NEWSLETTER_QUERY = `*[
	_type == "newsletterIssue"
	&& slug.current == $slug
][0]{
	_id,
	title,
	slug,
	publishedAt,
	excerpt,
	topics,
	leadStoryTitle,
	leadStoryIntro,
	heroImage,
	content
}`;

const { slug } = Astro.params as { slug: string };

const newsletter = await sanityClient.fetch<NewsletterPage | null>(NEWSLETTER_QUERY, {
	slug,
});

if (!newsletter) {
	return Astro.redirect('/newsletter');
}

const newsletterHeroWidths = [640, 960, 1280, 1600];
const newsletterHeroAspectRatio = 1280 / 822;
const newsletterImageUrl = newsletter.heroImage
	? getSanityImageUrl(newsletter.heroImage, {
			width: 1280,
			aspectRatio: newsletterHeroAspectRatio,
			fit: 'crop',
		})
	: null;
const newsletterImageSrcSet = newsletter.heroImage
	? getSanityImageSrcSet(newsletter.heroImage, newsletterHeroWidths, {
			aspectRatio: newsletterHeroAspectRatio,
			fit: 'crop',
		})
	: '';
const newsletterImageAlt = newsletter.heroImage?.alt || newsletter.title;
const publishedDate = new Intl.DateTimeFormat('en-GB', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(new Date(newsletter.publishedAt));

---

<SiteLayout title={newsletter.title}>
	<div class="space-y-8">
		<a
			href="/newsletter"
			class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-md ring-1 ring-gray-100 transition hover:bg-green-50 hover:text-[#2d5016]"
		>
			<ArrowLeft class="h-4 w-4" />
			<span>Back to newsletter</span>
		</a>

		<ContentFeatureCard>
			<Fragment slot="intro">
				<div class="flex items-center gap-3 text-green-800">
					<Archive class="h-6 w-6" />
					<p class="text-sm font-semibold uppercase tracking-[0.18em]">{publishedDate}</p>
				</div>
				<h1 class="mt-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
					{newsletter.title}
				</h1>
				<p class="mt-4 max-w-2xl text-lg leading-8 text-gray-600">{newsletter.excerpt}</p>
				{
					newsletter.topics?.length ? (
						<ul class="mt-5 flex flex-wrap gap-2">
							{
								newsletter.topics.map((topic) => (
									<li class="rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-800">
										{topic}
									</li>
								))
							}
						</ul>
					) : null
				}
			</Fragment>

			<Fragment slot="media">
				{
					newsletterImageUrl ? (
						<img
							src={newsletterImageUrl}
							srcset={newsletterImageSrcSet || undefined}
							sizes="(min-width: 1024px) 45vw, 100vw"
							alt={newsletterImageAlt}
							loading="eager"
							fetchpriority="high"
							decoding="async"
							width="1280"
							height="822"
							class="aspect-[1280/822] h-full min-h-72 w-full object-cover"
						/>
					) : (
						<div class="flex h-full min-h-72 items-center justify-center bg-linear-to-br from-lime-100 via-stone-50 to-emerald-100 text-green-900">
							<Archive class="h-16 w-16" />
						</div>
					)
				}
			</Fragment>

			<p class="mt-3 text-lg leading-8 text-gray-600">{newsletter.leadStoryIntro}</p>

			{
				Array.isArray(newsletter.content) && newsletter.content.length && (
					<div class="mt-8">
						<PortableText value={newsletter.content} components={articlePortableTextComponents} />
					</div>
				)
			}
		</ContentFeatureCard>
	</div>
</SiteLayout>
