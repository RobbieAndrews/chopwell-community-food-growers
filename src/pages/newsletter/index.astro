---
import SiteLayout from '../../layouts/SiteLayout.astro';
import FullBleedSection from '../../components/FullBleedSection.astro';
import PageIntro from '../../components/PageIntro.astro';
import { Archive, Mail, Newspaper, Sparkles } from '@lucide/astro';
import { sanityClient } from 'sanity:client';

interface NewsletterArchiveCard {
	_id: string;
	title: string;
	slug: { current: string };
	publishedAt: string;
	excerpt: string;
	topics?: string[];
}

const NEWSLETTER_ARCHIVE_QUERY = `*[
	_type == "newsletterIssue"
	&& defined(slug.current)
]|order(publishedAt desc){
	_id,
	title,
	slug,
	publishedAt,
	excerpt,
	topics
}`;

const newsletters = await sanityClient.fetch<NewsletterArchiveCard[]>(NEWSLETTER_ARCHIVE_QUERY);
const dateFormatter = new Intl.DateTimeFormat('en-GB', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});
---

<SiteLayout title="Newsletter">
	<div class="space-y-8">
		<section class="px-2 py-4 sm:px-0 sm:py-6">
			<div class="space-y-8">
				<PageIntro
					title="Newsletter"
					description="Stay connected with our community newsletter for seasonal updates, practical growing tips, recipes, and stories from around Chopwell."
					pills={[
						{
							label: `${newsletters.length} issue${newsletters.length !== 1 ? 's' : ''}`,
							icon: Newspaper,
							iconClass: 'text-green-700',
						},
						{
							label: 'Tips, recipes, and updates',
							icon: Sparkles,
							iconClass: 'text-amber-600',
						},
					]}
				/>

				<section class="rounded-4xl bg-white px-6 py-8 shadow-xl ring-1 ring-gray-100 sm:px-8 sm:py-10">
					<div class="max-w-2xl">
						<div class="flex items-center gap-3 text-[#2d5016]">
							<Mail class="h-8 w-8" />
							<h2 class="text-3xl font-bold tracking-tight text-gray-900">Subscribe</h2>
						</div>
						<p class="mt-4 text-lg leading-8 text-gray-600">
							Get the latest news, growing tips, recipes, and event updates delivered to
							your inbox every quarter.
						</p>
						<form class="mt-6 flex flex-col gap-3 sm:flex-row">
							<input
								type="email"
								placeholder="Enter your email address"
								class="min-w-0 flex-1 rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 placeholder-gray-500 outline-none transition focus:border-[#2d5016] focus:bg-white"
							/>
							<button
								type="submit"
								class="rounded-full bg-[#2d5016] px-8 py-3 font-semibold whitespace-nowrap text-white transition hover:bg-[#244111]"
							>
								Subscribe Now
							</button>
						</form>
						<p class="mt-3 text-xs text-gray-500">
							We respect your privacy. Unsubscribe at any time.
						</p>
					</div>
				</section>
			</div>
		</section>

		<FullBleedSection class="py-12" bleedClass="bleed-white-70">
				<div class="flex items-center gap-3">
					<Archive class="h-7 w-7 text-green-800" />
					<h2 class="text-2xl font-bold tracking-tight text-gray-900">Newsletter Archive</h2>
				</div>

				<div class="mt-6 space-y-6">
					{
						newsletters.length ? (
							newsletters.map((newsletter) => (
								<article class="rounded-4xl border border-gray-200 bg-white p-6 transition hover:shadow-lg">
									<div class="flex flex-col gap-4">
										<div class="flex-1">
											<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
												<h3 class="text-2xl font-bold tracking-tight text-gray-900">
													<a
														href={`/newsletter/${newsletter.slug.current}`}
														class="transition hover:text-green-800"
													>
														{newsletter.title}
													</a>
												</h3>
												<p class="text-sm text-gray-500">
													{dateFormatter.format(new Date(newsletter.publishedAt))}
												</p>
											</div>

											<p class="mt-3 text-gray-600">{newsletter.excerpt}</p>

											{
												newsletter.topics?.length ? (
													<ul class="mt-4 flex flex-wrap gap-2">
														{
															newsletter.topics.map((topic) => (
																<li class="rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-800">
																	{topic}
																</li>
															))
														}
													</ul>
												) : null
											}
										</div>
									</div>
								</article>
							))
						) : (
							<div class="rounded-4xl border border-dashed border-gray-300 bg-white/80 p-8 text-center text-gray-600">
								No newsletter issues have been published yet. Add one in Sanity and it will appear here.
							</div>
						)
					}
				</div>
		</FullBleedSection>

		<section class="rounded-4xl bg-[#2d5016] p-6 text-white shadow-2xl sm:p-8">
			<h2 class="text-2xl font-bold tracking-tight">Contribute to the Newsletter</h2>
			<p class="mt-3 max-w-3xl leading-8 text-green-50">
				We welcome contributions from community members. Share growing success stories,
				favourite recipes, practical tips, or photos for future editions.
			</p>
			<a
				href="/contact"
				class="mt-6 inline-flex items-center justify-center rounded-full bg-white px-8 py-3 font-semibold text-[#2d5016] transition hover:bg-green-50"
			>
				Submit Content
			</a>
		</section>
	</div>
</SiteLayout>
