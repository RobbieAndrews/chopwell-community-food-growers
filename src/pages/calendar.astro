---
import SiteLayout from '../layouts/SiteLayout.astro';
import Calendar from '../components/calendar/Calendar';
import { sanityClient } from 'sanity:client';
import type { CalendarEvent } from '../components/calendar/types';

const CALENDAR_EVENTS_QUERY = `*[
	_type == "calendarEvent"
	&& defined(date)
	&& defined(startTime)
	&& defined(endTime)
]|order(date asc, startTime asc){
	"title": title,
	"id": _id,
	date,
	startTime,
	endTime,
	category,
	description
}`;

const calendarEvents = await sanityClient.fetch<CalendarEvent[]>(CALENDAR_EVENTS_QUERY);
---

<SiteLayout title="Calendar">
	<Calendar client:load events={calendarEvents} />
</SiteLayout>
