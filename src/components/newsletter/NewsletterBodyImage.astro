---
import {urlForImage, type SanityImageWithAlt} from '../../lib/sanity';

type NewsletterBodyImageNode = SanityImageWithAlt & {
	_type: 'newsletterBodyImage';
	caption?: string;
};

const { node } = Astro.props as { node: NewsletterBodyImageNode };
const imageUrl = urlForImage(node)?.width(1200).fit('max').url();
const imageAlt = node.alt || '';
---

{
	imageUrl && (
		<figure class="not-prose my-8 flex flex-col items-center">
			<div class="overflow-hidden rounded-3xl border border-stone-200 bg-stone-50">
				<img
					src={imageUrl}
					alt={imageAlt}
					loading="lazy"
					class="mx-auto block h-auto max-w-full object-contain"
				/>
			</div>
			{
				node.caption ? (
					<figcaption class="mt-3 max-w-2xl text-center text-sm leading-6 text-stone-600">
						{node.caption}
					</figcaption>
				) : null
			}
		</figure>
	)
}
