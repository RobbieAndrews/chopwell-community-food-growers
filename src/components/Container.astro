---
interface Props {
	as?: keyof HTMLElementTagNameMap;
	size?: 'narrow' | 'default' | 'wide' | 'full';
	class?: string;
}

const {
	as = 'div',
	size = 'default',
	class: className = '',
} = Astro.props as Props;

const As = as;

const sizeClasses = {
	narrow: 'mx-auto w-full max-w-3xl px-4 sm:px-6 lg:px-8',
	default: 'mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8',
	wide: 'mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8',
	full: 'w-full',
};
---

<As class:list={[sizeClasses[size], className]}>
	<slot />
</As>
