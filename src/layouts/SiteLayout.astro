---
import "../styles/global.css";
import { Sprout } from "@lucide/astro";
import Container from "../components/Container.astro";

interface Props {
    title: string;
    mainClass?: string;
    wrapContent?: boolean;
}

const {
    title,
    mainClass = "py-10 sm:py-14",
    wrapContent = true,
} = Astro.props;
const siteTitle = "Chopwell Community Food Growers";
const pathname = Astro.url.pathname;
const navLinks = [
    { href: "/", label: "Home" },
    { href: "/projects", label: "Projects" },
    { href: "/calendar", label: "Calendar" },
    { href: "/newsletter", label: "Newsletter" },
    { href: "/get-involved", label: "Get Involved" },
    { href: "/contact", label: "Contact" },
    { href: "/useful-links", label: "Useful Links" },
];
const desktopNavLinks = navLinks.filter(({ href }) => href !== "/");
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | {siteTitle}</title>
    </head>
    <body>
        <div class="min-h-screen">
            <header
                class="sticky top-0 z-40 border-b border-green-900/10 bg-white"
            >
                <Container class="py-4 sm:py-5">
                    <div class="md:hidden">
                        <details data-mobile-menu class="group mobile-menu">
                            <summary
                                class="mobile-menu__summary relative z-70 flex w-full cursor-pointer list-none items-center gap-3 bg-white text-gray-900"
                            >
                                <span class="sr-only"
                                    >Toggle navigation menu</span
                                >
                                <span
                                    class="flex rounded-full bg-green-50 p-3 text-[#2d5016] transition hover:bg-green-100"
                                >
                                    <span class="flex flex-col gap-1.5">
                                        <span
                                            class="block h-0.5 w-5 rounded-full bg-current transition group-open:translate-y-2 group-open:rotate-45"
                                        ></span>
                                        <span
                                            class="block h-0.5 w-5 rounded-full bg-current transition group-open:opacity-0"
                                        ></span>
                                        <span
                                            class="block h-0.5 w-5 rounded-full bg-current transition group-open:-translate-y-2 group-open:-rotate-45"
                                        ></span>
                                    </span>
                                </span>
                                <span
                                    class="flex items-center gap-2 text-base font-semibold tracking-tight text-green-800"
                                >
                                    <Sprout />
                                    <span>{siteTitle}</span>
                                </span>
                            </summary>
                            <div class="mobile-menu__overlay">
                                <nav
                                    aria-label="Primary navigation"
                                    class="mobile-menu__panel absolute left-0 top-0 flex h-dvh min-h-screen w-screen flex-col bg-white text-gray-900 shadow-2xl"
                                >
                                    <ul class="mobile-menu__list flex flex-1 flex-col gap-2 bg-white px-4 pb-5 pt-24">
                                        {
                                            navLinks.map(({ href, label }) => {
                                                const isActive = pathname === href;

                                                return (
                                                    <li class="rounded-lg">
                                                        <a
                                                            href={href}
                                                            aria-current={
                                                                isActive
                                                                    ? "page"
                                                                    : undefined
                                                            }
                                                            class:list={[
                                                                "block rounded-xl px-4 py-3 text-sm font-medium text-gray-700 transition hover:bg-green-50 hover:text-[#2d5016]",
                                                                isActive
                                                                    ? "bg-[#2d5016] text-white"
                                                                    : "",
                                                            ]}
                                                            data-close-menu
                                                        >
                                                            {label}
                                                        </a>
                                                    </li>
                                                );
                                            })
                                        }
                                    </ul>
                                </nav>
                            </div>
                        </details>
                    </div>

                    <div
                        class="hidden items-center justify-between gap-4 md:flex"
                    >
                        <a
                            href="/"
                            class="flex items-center gap-3 text-lg font-semibold tracking-tight text-[#2d5016] transition"
                        >
                            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-green-50 shadow-sm">
                                <Sprout class="h-5 w-5" />
                            </div>
                            {siteTitle}
                        </a>

                        <nav aria-label="Primary navigation">
                            <ul class="flex flex-wrap gap-x-2 gap-y-2">
                                {
                                    desktopNavLinks.map(({ href, label }) => {
                                        const isActive = pathname === href;

                                        return (
                                            <li class="rounded-lg">
                                                <a
                                                    href={href}
                                                    aria-current={
                                                        isActive
                                                            ? "page"
                                                            : undefined
                                                    }
                                                    class:list={[
                                                        "block rounded-full px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-green-50 hover:text-[#2d5016]",
                                                        isActive
                                                            ? "font-semibold text-[#2d5016]"
                                                            : "",
                                                    ]}
                                                >
                                                    {label}
                                                </a>
                                            </li>
                                        );
                                    })
                                }
                            </ul>
                        </nav>
                    </div>
                </Container>
            </header>

            <main class={mainClass}>
                {
                    wrapContent ? (
                        <Container>
                            <slot />
                        </Container>
                    ) : (
                        <slot />
                    )
                }
            </main>
        </div>
    </body>
</html>

<script>
    const mobileMenus = document.querySelectorAll("[data-mobile-menu]");

    const syncMobileMenuState = () => {
        const hasOpenMenu = Array.from(mobileMenus).some((menu) =>
            menu.hasAttribute("open")
        );

        document.body.classList.toggle("mobile-menu-open", hasOpenMenu);
    };

    mobileMenus.forEach((menu) => {
        menu.addEventListener("toggle", syncMobileMenuState);

        menu.querySelectorAll("[data-close-menu]").forEach((element) => {
            element.addEventListener("click", () => {
                menu.removeAttribute("open");
                syncMobileMenuState();
            });
        });
    });

    syncMobileMenuState();
</script>

<style>
    .mobile-menu__summary::-webkit-details-marker {
        display: none;
    }

    .mobile-menu__overlay {
        position: fixed;
        inset: 0;
        z-index: 45;
        pointer-events: none;
        opacity: 0;
        background: #ffffff;
        transition: opacity 200ms ease;
    }

    .mobile-menu__panel {
        transform: translateX(-100%);
        transition: transform 240ms ease;
        overflow-y: auto;
    }

    .mobile-menu__list {
        min-height: 100%;
    }

    .mobile-menu[open] > .mobile-menu__overlay {
        pointer-events: auto;
        opacity: 1;
    }

    .mobile-menu[open] .mobile-menu__panel {
        transform: translateX(0);
    }

    :global(body.mobile-menu-open) {
        overflow: hidden;
    }
</style>
